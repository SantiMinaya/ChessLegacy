{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/ChessLegacy.API/Dockerfile",
    "dockerContextPath": "backend/ChessLegacy.API"
  },
  "deploy": {
    "healthcheckPath": "/api/clasificacion",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
